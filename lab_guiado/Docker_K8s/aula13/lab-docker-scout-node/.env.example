# Bases usadas no laboratório.
# A imagem antiga é proposital para gerar alertas e facilitar a demonstração do Docker Scout.
OLD_BASE_IMAGE=node:16-alpine

# No print do Docker Scout usado como referência, a recomendação aparece como node:26-alpine.
# Se a tag ainda não estiver disponível no ambiente da aula, use node:24-alpine ou node:22-alpine.
UPDATED_BASE_IMAGE=node:26-alpine

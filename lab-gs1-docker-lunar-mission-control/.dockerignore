# Version control
.git
.gitignore

# Dependencies (rebuilt inside the image)
node_modules
npm-debug.log*
yarn-error.log*

# Environment / secrets (never bake into image)
.env
.env.*
!.env.example

# Docker files (not needed at runtime)
docker-compose*.yml
Dockerfile*
.dockerignore

# Documentation
*.md
image.png

# OS artefacts
**/.DS_Store
**/Thumbs.db

# Nginx config (mounted as volume, not baked in)
nginx/

# Scan results
trivy-results/

# ─────────────────────────────────────────────────────────────────────────────
# Lunar Mission Control — environment variables
# IMPORTANT: never commit a real .env to a public repo in production.
# ─────────────────────────────────────────────────────────────────────────────

# Application
APP_PORT=3000
NODE_ENV=production
MISSION_NAME=Artemis FIAP Lunar Base
PUBLIC_HTTP_PORT=80

# MySQL (used by the mysql service AND mapped to DB_* for the app service)
MYSQL_DATABASE=lunar_mission
MYSQL_USER=lunar_user
MYSQL_PASSWORD=Lunar@4rtem1s#2025!
MYSQL_ROOT_PASSWORD=R00t@Lunar$$M1ss10n#2025

# Redis (consumed directly by the app via REDIS_HOST / REDIS_PORT)
REDIS_HOST=redis
REDIS_PORT=6379

# Grafana (Item Plus — Observabilidade)
GRAFANA_PASSWORD=LunarGrafana@2025

# ECR — AWS Image Registry (Item Plus)
# Preencher com os dados da sua conta AWS antes de rodar make ecr-push
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=YOUR_ACCOUNT_ID
ECR_REPO=lunar-mission-control-app
ECR_TAG=1.0.0
